# Public Apache port on the host.
APACHE_HTTP_PORT=8080

# Single web image containing WordPress, Apache/PHP, Adminer, MariaDB, Redis, and local routing.
WEB_IMAGE=ghcr.io/shubkb07/wp-local:0.0.2-alpha

# Where each site's wp-content and per-site wp-config.php are stored.
WP_SITES_PATH=./data/wp-sites

# Root-capable MySQL credentials used by WordPress and Adminer.
MYSQL_USER=root
MYSQL_PASSWORD=local_root_password

# Comma-separated local WordPress hostnames.
SITES=apple.local,meow.local
